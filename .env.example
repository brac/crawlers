# Copy to .env (gitignored) and edit. Compose reads .env automatically.
# Most values have a sensible default in docker-compose.yml; POSTGRES_PASSWORD
# is the exception — it is required and has no default, so this file (or a
# shell env var) must provide it.

# --- ASP.NET server ---
# Host port the server is exposed on. Container always listens on 8080.
# Defaults to 127.0.0.1 (localhost-only). To expose the server on all
# interfaces, set e.g. SERVER_HOST_PORT=0.0.0.0:5238 (put TLS in front first).
SERVER_HOST_PORT=127.0.0.1:5238

# Production / Development / Staging. Affects logging + dev-only middleware.
ASPNETCORE_ENVIRONMENT=Production

# Comma-separated list of origins allowed to make CORS requests directly to
# the SignalR hub. Not relevant when the client talks through a same-origin
# reverse proxy (Vite dev does this).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Postgres ---
POSTGRES_USER=crawlers
# REQUIRED — no default in docker-compose.yml. The value below is a local-dev
# convenience only; the DB binds to 127.0.0.1 so it isn't reachable off-host.
# Always set a strong, unique password in any deployed environment.
POSTGRES_PASSWORD=dev-only-change-me
POSTGRES_DB=crawlers

# Host port for direct DB access (psql, pgAdmin). Defaults to 127.0.0.1
# (localhost-only). The server container always reaches Postgres on its
# compose-network alias `postgres:5432`, independent of this mapping.
POSTGRES_HOST_PORT=127.0.0.1:5432
