# Copy to .env (gitignored) and edit. Compose reads .env automatically.
# Every value below has a sensible default in docker-compose.yml; this file
# documents what's available to override.

# --- ASP.NET server ---
# Host port the server is exposed on. Container always listens on 8080.
SERVER_HOST_PORT=5238

# Production / Development / Staging. Affects logging + dev-only middleware.
ASPNETCORE_ENVIRONMENT=Production

# Comma-separated list of origins allowed to make CORS requests directly to
# the SignalR hub. Not relevant when the client talks through a same-origin
# reverse proxy (Vite dev does this).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Postgres ---
POSTGRES_USER=crawlers
POSTGRES_PASSWORD=crawlers
POSTGRES_DB=crawlers

# Host port for direct DB access (psql, pgAdmin). The server container always
# reaches Postgres on its compose-network alias `postgres:5432`.
POSTGRES_HOST_PORT=5432
